/* Catppuccin Mocha Palette */
@define-color base      #1e1e2e;
@define-color mantle    #181825;
@define-color crust     #11111b;
@define-color text      #cdd6f4;
@define-color subtext0  #a6adc8;
@define-color subtext1  #bac2de;
@define-color surface0  #313244;
@define-color surface1  #45475a;
@define-color surface2  #585b70;

/* Pastel Accents */
@define-color blue      #8caaee;
@define-color green     #a6e3a1;
@define-color red       #f38ba8;
@define-color mauve     #cba6f7;
@define-color pink      #f5c2e7;

/* 1. Reset borders and sizing globally, but DO NOT set colors here */
* {
    border: none;
    box-shadow: none;
    text-shadow: none;
    min-height: 0; 
}

/* 2. Set your global fonts and base color here so they inherit naturally */
window#waybar {
    font-family: "JetBrainsMono Nerd Font", Roboto, Helvetica, Arial, sans-serif;
    font-size: 16px;
    color: @text;
    background: transparent;
}

/* -----------------------------------------------------
 * Base Module Styling
 * ----------------------------------------------------- */
#clock,
#network,
#bluetooth,
#workspaces {
    background-color: @mantle; 
    border: 2px solid; 
    padding: 2px 14px;
    margin: 4px 4px;
    border-radius: 15px;
    font-weight: bold;
}

/* -----------------------------------------------------
 * Specific Modules
 * ----------------------------------------------------- */
#clock {
    color: @pink;
    border-color: @pink;
}

#bluetooth {
    color: @blue;
    border-color: @blue;
    margin-right: 0px;
    border-top-right-radius: 0px;
    border-bottom-right-radius: 0px;
    border-right: none; 
}

#network {
    color: @green;
    border-color: @blue; 
    margin-left: 0px;
    border-top-left-radius: 0px;
    border-bottom-left-radius: 0px;
}

#network.disconnected {
    color: @red;
}

/* -----------------------------------------------------
 * Workspaces
 * ----------------------------------------------------- */
#workspaces {
    border-color: @mauve;
    padding: 2px 6px;
}

#workspaces button {
    color: @subtext0;
    background: transparent;
    padding: 0 8px;
    margin: 2px;
    border-radius: 10px;
    transition: all 0.2s ease;
}

#workspaces button:hover {
    color: @text;
    background: @surface1;
}

#workspaces button.persistent {
    font-weight: bold;
    color: @subtext1;
}

#workspaces button.empty {
    color: @surface2;
}

/* 3. Now this works perfectly without needing any messy label targets */
#workspaces button.active,
#workspaces button.visible {
    color: #000000; 
    background-color: @mauve; 
    font-weight: bold;
    min-width: 40px;
}
